# ── Admin credentials (single user) ──
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# ── Session signing (HMAC). Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))" ──
SESSION_SECRET=replace-with-a-long-random-hex-string

# ── Vercel KV (Upstash Redis) — provision in Vercel dashboard ──
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Vercel Blob — provision in Vercel dashboard ──
BLOB_READ_WRITE_TOKEN=

# ── Optional: hide the floating "Admin" button on the public site ──
# Leave unset (or "false") in dev to keep it visible; set "true" in prod env vars on Vercel.
PUBLIC_HIDE_ADMIN_FAB=false
