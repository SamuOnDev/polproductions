---
import type { ActiveLang } from "../i18n";

type Dict = Record<string, string>;

interface Props {
  activeLang: ActiveLang;
  t: Dict;
}

const { activeLang, t } = Astro.props;

const links = [
  { href: `/${activeLang}/`, label: t.nav_home },
  { href: `/${activeLang}/trabajos/`, label: t.nav_portfolio },
  { href: `/${activeLang}/proceso/`, label: t.nav_process },
  { href: `/${activeLang}/sobre-mi/`, label: t.nav_about },
  { href: `/${activeLang}/contacto/`, label: t.nav_contact },
];
---

<header class="site-header border-b border-white/20">
  <div class="mx-auto max-w-6xl px-4 py-4 md:py-5">
    <div class="flex items-center justify-between gap-3">
      <a href={`/${activeLang}/`} class="text-xl font-black italic tracking-tight sm:text-2xl md:text-3xl">
      POL <span class="text-brand-accent text-xs not-italic">PRODUCCIONES</span>
      </a>

      <div class="flex items-center gap-2 text-xs sm:gap-3 sm:text-sm">
        <a class="gold-btn rounded-md px-3 py-2 font-bold text-black sm:px-4" href={`/${activeLang}/contacto/`}>{t.nav_cta}</a>
        <a class={activeLang === "es" ? "text-brand-accent" : "text-white/70"} href="/es/">ES</a>
        <span class="text-white/50">|</span>
        <a class={activeLang === "en" ? "text-brand-accent" : "text-white/70"} href="/en/">EN</a>
      </div>
    </div>

    <nav class="mt-3 flex gap-5 overflow-x-auto pb-1 text-sm whitespace-nowrap md:mt-4 md:justify-end md:overflow-visible">
      {links.map((link) => (
        <a href={link.href} class="text-white/80 transition hover:text-brand-accent">{link.label}</a>
      ))}
    </nav>
  </div>
</header>
