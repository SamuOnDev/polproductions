---
import type { ActiveLang, LocaleTexts } from "../i18n";
import { makeText, makeEk } from "../lib/page-text";

interface Props {
    activeLang: ActiveLang;
    t: LocaleTexts;
    overrides?: Record<string, string>;
    editMode?: boolean;
}

const { activeLang, t, overrides = {}, editMode = false } = Astro.props;
const base = `/${activeLang}`;
const text = makeText(t, overrides);
const ek = makeEk(editMode);
const phoneHref = "tel:" + text("contact_phone").replace(/\s+/g, "");
const emailHref = "mailto:" + text("contact_email");
---

<footer>
    <div class="container">
        <div class="foot-top">
            <div class="foot-brand">
                <h3>Pol<br /><b>Sánchez Baena</b></h3>
                <p data-cms-key={ek("footer_tagline")}>{text("footer_tagline")}</p>
            </div>
            <div class="foot-col">
                <h5 data-cms-key={ek("footer_nav_title")}>{text("footer_nav_title")}</h5>
                <a href={`${base}/#work`} data-cms-key={ek("nav_work")}>{text("nav_work")}</a>
                <a href={`${base}/#vertical`} data-cms-key={ek("nav_vertical")}>{text("nav_vertical")}</a>
                <a href={`${base}/portfolio`} data-cms-key={ek("nav_portfolio")}>{text("nav_portfolio")}</a>
                <a href={`${base}/#about`} data-cms-key={ek("nav_about")}>{text("nav_about")}</a>
                <a href={`${base}/#contact`} data-cms-key={ek("nav_contact")}>{text("nav_contact")}</a>
            </div>
            <div class="foot-col">
                <h5 data-cms-key={ek("footer_contact_title")}>{text("footer_contact_title")}</h5>
                <a href={emailHref} data-cms-key={ek("contact_email")}>{text("contact_email")}</a>
                <a href={phoneHref} data-cms-key={ek("contact_phone")}>{text("contact_phone")}</a>
                <a href="#" data-cms-key={ek("footer_location")}>{text("footer_location")}</a>
            </div>
            <div class="foot-col">
                <h5 data-cms-key={ek("footer_social_title")}>{text("footer_social_title")}</h5>
                <a href="#">Instagram</a>
                <a href="#">YouTube</a>
                <a href="#">Vimeo</a>
                <a href="#">LinkedIn</a>
            </div>
        </div>
        <div class="foot-bottom">
            <span><b data-cms-key={ek("footer_copyright")}>{text("footer_copyright")}</b></span>
            <span class="mono" data-cms-key={ek("footer_version")}>{text("footer_version")}</span>
            <span class="mono powered-by">
                Powered by <a href="https://usenorlia.com" target="_blank" rel="noopener noreferrer">Norlia</a>
            </span>
        </div>
    </div>
</footer>
