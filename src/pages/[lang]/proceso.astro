---
import type { ActiveLang } from "../../i18n";
import { LANGS, DEFAULT_LANG, getDict } from "../../i18n";
import SiteHeader from "../../components/SiteHeader.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
    return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang?: ActiveLang };
const activeLang = lang ?? DEFAULT_LANG;
const t = await getDict(activeLang);

const steps = [
    { number: "01", title: t.process_step_1_title, desc: t.process_step_1_desc },
    { number: "02", title: t.process_step_2_title, desc: t.process_step_2_desc },
    { number: "03", title: t.process_step_3_title, desc: t.process_step_3_desc },
    { number: "04", title: t.process_step_4_title, desc: t.process_step_4_desc },
];
---

<html lang={activeLang}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>{t.process_page_title}</title>
        <meta name="description" content={t.process_page_description} />
    </head>

    <body class="site-bg min-h-screen text-brand-text antialiased">
        <SiteHeader activeLang={activeLang} t={t} />

        <main class="mx-auto max-w-6xl px-4 pb-16 pt-36 md:pt-32">
            <section class="scroll-section card-frame rounded-xl border border-white/20 bg-black/45 p-8 md:p-12">
                <p class="text-sm uppercase tracking-[0.18em] text-brand-accent">{t.process_kicker}</p>
                <h1 class="mt-4 max-w-3xl text-3xl font-black md:text-6xl">{t.process_title}</h1>
                <p class="mt-6 max-w-3xl text-lg text-white/80 md:text-2xl">{t.process_intro}</p>
                <div class="mt-7 grid gap-4 sm:grid-cols-2">
                    <div class="card-frame rounded-lg border border-white/20 bg-white/[0.03] p-5">
                        <p class="text-sm uppercase tracking-[0.12em] text-white/65">{t.process_duration}</p>
                        <p class="mt-2 text-3xl font-black">{t.process_duration_value}</p>
                    </div>
                    <div class="card-frame rounded-lg border border-white/20 bg-white/[0.03] p-5">
                        <p class="text-sm uppercase tracking-[0.12em] text-white/65">{t.process_guarantee_title}</p>
                        <ul class="mt-3 space-y-2 text-base text-white/85">
                            <li>• {t.process_guarantee_1}</li>
                            <li>• {t.process_guarantee_2}</li>
                            <li>• {t.process_guarantee_3}</li>
                        </ul>
                    </div>
                </div>
            </section>

            <section class="scroll-section mt-10">
                <div class="mb-6">
                    <h2 class="text-3xl font-black md:text-5xl">{t.process_block_title}</h2>
                    <p class="mt-3 max-w-3xl text-lg text-white/75 md:text-xl">{t.process_block_desc}</p>
                </div>

                <div class="relative grid gap-5">
                    <div class="absolute left-[1.15rem] top-6 hidden h-[calc(100%-3rem)] w-px bg-gradient-to-b from-brand-accent/70 via-brand-accent/40 to-transparent md:block"></div>
                    {steps.map((step) => (
                        <article class="card-frame relative rounded-lg border border-white/20 bg-black/40 p-6 pl-16 shadow-[0_14px_30px_rgb(0_0_0_/_0.35)]">
                            <span class="absolute left-4 top-6 flex h-8 w-8 items-center justify-center rounded-full border border-brand-accent/80 bg-black text-xs font-bold text-brand-accent">{step.number}</span>
                            <h3 class="text-2xl font-black md:text-3xl">{step.title}</h3>
                            <p class="mt-2 text-base text-white/80 md:text-lg">{step.desc}</p>
                        </article>
                    ))}
                </div>
            </section>

            <section class="scroll-section card-frame mt-10 grid gap-5 rounded-xl border border-white/20 bg-black/45 p-8 md:grid-cols-[1.2fr_1fr] md:p-10">
                <div>
                    <h2 class="text-3xl font-black md:text-5xl">{t.process_close_title}</h2>
                    <p class="mt-4 text-lg text-white/80 md:text-xl">{t.process_close_desc}</p>
                    <a href={`/${activeLang}/#contact`} class="gold-btn mt-7 inline-block rounded-md px-7 py-3 text-lg font-bold text-black">{t.process_cta}</a>
                </div>
                <aside class="rounded-lg border border-brand-accent/40 bg-brand-accent/[0.08] p-5 text-white/90">
                    <p class="text-lg">{t.process_close_side}</p>
                </aside>
            </section>
        </main>

        <script is:inline>
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-visible");
                        }
                    });
                },
                { threshold: 0.15 },
            );

            document.querySelectorAll(".scroll-section").forEach((section) => {
                observer.observe(section);
            });
        </script>
    </body>
</html>
