---
import type { ActiveLang } from "../../i18n";
import { LANGS, DEFAULT_LANG, getDict } from "../../i18n";
import SiteHeader from "../../components/SiteHeader.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
    return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang?: ActiveLang };
const activeLang = lang ?? DEFAULT_LANG;
const t = await getDict(activeLang);
---

<html lang={activeLang}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>{t.contact_page_title}</title>
        <meta name="description" content={t.contact_page_description} />
    </head>

    <body class="site-bg min-h-screen text-brand-text antialiased">
        <SiteHeader activeLang={activeLang} t={t} />

        <main class="mx-auto max-w-4xl px-4 pb-20 pt-28 md:pt-32">
            <section class="scroll-section rounded-xl border border-white/20 bg-black/45 p-6 md:p-10">
                <p class="text-sm tracking-[0.2em] text-brand-accent">{t.contact_subtitle.toUpperCase()}</p>
                <h1 class="mt-3 text-4xl font-black md:text-6xl">{t.contact_heading}</h1>
                <p class="mt-5 text-white/80">{t.contact_ready_desc}</p>

                <form class="mt-8 border border-white/25 bg-black/40 p-6">
                    <input class="form-line" placeholder={t.form_name} />
                    <input class="form-line" placeholder={t.form_email} />
                    <textarea class="form-line h-28" placeholder={t.form_message}></textarea>
                    <div class="mt-6 text-right">
                        <button class="gold-btn rounded-md px-10 py-3 text-2xl font-bold text-black" type="submit">{t.contact_send}</button>
                    </div>
                </form>
            </section>
        </main>

        <script is:inline>
            const section = document.querySelector(".scroll-section");
            if (section) {
                requestAnimationFrame(() => section.classList.add("is-visible"));
            }
        </script>
    </body>
</html>
