---
import type { ActiveLang } from "../../../i18n";
import { LANGS, DEFAULT_LANG, getDict } from "../../../i18n";
import { getProjectBySlug, projects } from "../../../data/projects";
import SiteHeader from "../../../components/SiteHeader.astro";
import "../../../styles/global.css";

export async function getStaticPaths() {
    return LANGS.flatMap((lang) => projects.map((project) => ({ params: { lang, slug: project.slug } })));
}

const { lang, slug } = Astro.params as { lang?: ActiveLang; slug?: string };
const activeLang = lang ?? DEFAULT_LANG;
const t = await getDict(activeLang);
const project = slug ? getProjectBySlug(slug) : undefined;

if (!project) {
    return Astro.redirect(`/${activeLang}/trabajos/`);
}
---

<html lang={activeLang}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>{project.title} | POL Producciones</title>
    </head>

    <body class="site-bg min-h-screen text-brand-text antialiased">
        <SiteHeader activeLang={activeLang} t={t} />

        <main class="mx-auto max-w-6xl px-4 pb-20 pt-36 md:pt-32">
            <div class="scroll-section flex flex-wrap items-center gap-3 text-white/70">
                <a class="back-link-frame" href={`/${activeLang}/trabajos/`}>← {t.project_back}</a>
                <span class="text-sm text-white/60 md:text-xl">/ {t.project_breadcrumb}</span>
            </div>

            <section class="scroll-section mt-6 grid gap-8 lg:grid-cols-[1fr_1.3fr]">
                <article>
                    <h1 class="text-3xl font-black leading-[1.05] sm:text-4xl md:text-6xl">{project.title}</h1>
                    <p class="mt-5 max-w-md text-lg text-white/80 md:text-2xl">{project.description}</p>

                    <div class="mt-6 flex flex-wrap gap-2">
                        {project.timeline.map((item) => <span class="detail-pill">{item}</span>)}
                    </div>

                    <div class="project-card card-frame mt-6 border border-white/15 bg-black/35 p-4">
                        <p class="text-white/75">Tints. 🎥 🎬 🎯 ⚙️ 🧪</p>
                        <p class="mt-4 text-white/80">Tech stack: {project.stack.join(" · ")}</p>
                        <a href="#" class="gold-btn mt-4 inline-flex rounded-md px-6 py-3 text-base font-bold text-black md:text-xl">▶ {t.project_visit}</a>
                    </div>
                </article>

                <article class="project-player p-4">
                    <img src={project.heroImage} alt={project.title} class="h-full w-full object-cover" />
                </article>
            </section>

            <section class="scroll-section mt-12 border-t border-white/20 pt-8">
                <h2 class="text-3xl font-black md:text-4xl">{t.project_details}</h2>
                <div class="project-card card-frame mt-5 grid border border-white/15 bg-black/40 lg:grid-cols-[1.9fr_1fr]">
                    <article class="p-6 lg:border-r lg:border-white/10">
                        <p class="text-lg text-white/80 md:text-xl">{t.project_detail_intro}</p>
                        <ul class="mt-4 list-disc space-y-2 pl-6 text-lg text-white/90 md:text-2xl">
                            {project.objectives.map((objective) => <li>{objective}</li>)}
                        </ul>

                        <div class="mt-8 grid gap-4 md:grid-cols-3">
                            {project.gallery.map((item) => (
                                <figure class="card-frame overflow-hidden border border-white/15 bg-black/40">
                                    <img src={item.image} alt={item.title} class="h-44 w-full object-cover" />
                                    <figcaption class="p-3 text-xl font-semibold md:text-2xl">{item.title}</figcaption>
                                </figure>
                            ))}
                        </div>
                    </article>

                    <aside class="p-6">
                        <h3 class="text-3xl font-black md:text-5xl">{t.project_results}</h3>
                        <ul class="mt-6 space-y-4 text-xl text-white/90 md:text-3xl">
                            {project.results.map((result) => <li class="border-b border-white/10 pb-3">✅ {result}</li>)}
                        </ul>
                    </aside>
                </div>
            </section>

            <section id="contact" class="scroll-section mt-12 grid gap-8 lg:grid-cols-2">
                <div>
                    <h2 class="text-3xl font-black md:text-5xl">{t.project_ready}</h2>
                    <p class="mt-4 text-lg text-white/75 md:text-2xl">{t.project_ready_desc}</p>
                    <a class="gold-btn mt-6 inline-block rounded-md px-8 py-3 text-lg font-bold text-black md:text-2xl" href={`/${activeLang}/contacto/`}>{t.project_contact}</a>
                </div>

                <form class="project-card card-frame border border-white/20 bg-black/30 p-6">
                    <input class="form-line" placeholder={t.form_email} />
                    <textarea class="form-line mt-6 h-28" placeholder={t.form_message}></textarea>
                    <div class="mt-8 text-right">
                        <button class="gold-btn rounded-md px-10 py-3 text-lg font-bold text-black md:text-2xl" type="submit">{t.form_submit}</button>
                    </div>
                </form>
            </section>
        </main>

        <script is:inline>
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-visible");
                        }
                    });
                },
                { threshold: 0.2, rootMargin: "0px 0px -60px 0px" },
            );

            document.querySelectorAll(".scroll-section").forEach((section) => {
                observer.observe(section);
            });
        </script>
    </body>
</html>
