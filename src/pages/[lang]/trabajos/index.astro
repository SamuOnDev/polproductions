---
import type { ActiveLang } from "../../../i18n";
import { LANGS, DEFAULT_LANG, getDict } from "../../../i18n";
import { projects } from "../../../data/projects";
import SiteHeader from "../../../components/SiteHeader.astro";
import "../../../styles/global.css";

export async function getStaticPaths() {
    return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang?: ActiveLang };
const activeLang = lang ?? DEFAULT_LANG;
const t = await getDict(activeLang);
---

<html lang={activeLang}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>{t.projects_title} | POL Producciones</title>
    </head>
    <body class="site-bg min-h-screen text-brand-text antialiased">
        <SiteHeader activeLang={activeLang} t={t} />

        <main class="mx-auto max-w-6xl px-4 pb-16 pt-28 md:pt-32">
            <section class="scroll-section">
                <h1 class="mt-4 text-5xl font-black md:text-6xl">{t.projects_title}</h1>
                <p class="mt-4 max-w-2xl text-xl text-white/75">{t.projects_subtitle}</p>
            </section>

            <section class="scroll-section mt-10 flex flex-wrap justify-center gap-5">
                {projects.map((project) => (
                    <article class="project-card card-frame w-full max-w-sm overflow-hidden border border-white/20 bg-black/50">
                        <div class="relative h-56">
                            <img src={project.heroImage} alt={project.title} class="h-full w-full object-cover" />
                            <span class="absolute left-4 top-4 rounded bg-black/80 px-3 py-1 text-sm font-semibold">{project.tag}</span>
                        </div>
                        <div class="p-5">
                            <h2 class="text-3xl font-bold">{project.title}</h2>
                            <p class="mt-2 text-lg text-white/75">{project.shortDescription}</p>
                            <a class="gold-btn mt-4 inline-block rounded px-4 py-2 font-bold text-black" href={`/${activeLang}/trabajos/${project.slug}/`}>
                                {t.projects_button}
                            </a>
                        </div>
                    </article>
                ))}
            </section>
        </main>

        <script is:inline>
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-visible");
                        }
                    });
                },
                { threshold: 0.2, rootMargin: "0px 0px -60px 0px" },
            );

            document.querySelectorAll(".scroll-section").forEach((section) => {
                observer.observe(section);
            });
        </script>
    </body>
</html>
