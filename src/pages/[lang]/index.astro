---
import type { ActiveLang } from "../../i18n";
import { LANGS, DEFAULT_LANG, getDict } from "../../i18n";
import { loadCms } from "../../lib/cms-store";
import { isEditMode } from "../../lib/edit-mode";
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = false;

const { lang } = Astro.params as { lang?: string };
if (!lang || !LANGS.includes(lang as ActiveLang)) {
    return Astro.redirect(`/${DEFAULT_LANG}/`, 308);
}
const activeLang = lang as ActiveLang;
const t = await getDict(activeLang);
const cms = await loadCms();
const editMode = await isEditMode(Astro.cookies, Astro.url);
const ek = (k: string): string | undefined => (editMode ? k : undefined);

const horizontal = cms.projects
    .filter((p) => p.type === "horizontal" && p.showOnHome !== false)
    .sort((a, b) => (a.order ?? 0) - (b.order ?? 0));
const vertical = cms.projects
    .filter((p) => p.type === "vertical" && p.showOnHome !== false)
    .sort((a, b) => (a.order ?? 0) - (b.order ?? 0));

function youtubeId(url: string | undefined): string | null {
    if (!url) return null;
    const m = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([\w-]{11})/);
    return m ? m[1] : null;
}

const horizontalCounts = {
    all: horizontal.length,
    clips: horizontal.filter((p) => p.tag === "Videoclip").length,
    ads: horizontal.filter((p) => p.tag === "Comercial").length,
    youtube: horizontal.filter((p) => p.tag === "YouTube").length,
    doc: horizontal.filter((p) => p.tag === "Documental").length,
};

const processSteps = [
    { num: "01", titleKey: "process_step_1_title", descKey: "process_step_1_desc", timeKey: "process_step_1_time" },
    { num: "02", titleKey: "process_step_2_title", descKey: "process_step_2_desc", timeKey: "process_step_2_time" },
    { num: "03", titleKey: "process_step_3_title", descKey: "process_step_3_desc", timeKey: "process_step_3_time" },
    { num: "04", titleKey: "process_step_4_title", descKey: "process_step_4_desc", timeKey: "process_step_4_time" },
];

const logoNames = [
    "Lume <i>Records</i>", "Northbeat", "Atlas <i>Studio</i>", "Vertigo",
    "Casa Mar", "Ediciones <i>Norte</i>", "Pulse Mag", "Halcón <i>Audio</i>",
];

const projectOptions = (t.form_project_options as unknown as string[]) || [];
const budgetOptions = (t.form_budget_options as unknown as string[]) || [];
const heroImage = cms.media.heroShowreelImage || cms.images["hero.showreel"] || "/images/hero-showreel-cover.jpg";
const aboutImage = cms.media.aboutPortraitImage || cms.images["about.portrait"] || "/images/hero-showreel-cover.jpg";
const showreelVideoUrl = cms.media.heroShowreelVideoUrl?.trim() || "";
const showreelYtId = youtubeId(showreelVideoUrl);
const showreelIsMp4 = showreelVideoUrl && !showreelYtId && /\.(mp4|webm|mov)(\?|$)/i.test(showreelVideoUrl);

const overrides = cms.text?.[activeLang] ?? {};
function text(key: string): string {
    const override = overrides[key];
    if (typeof override === "string" && override.length > 0) return override;
    const fallback = t[key];
    return typeof fallback === "string" ? fallback : "";
}

const pageTitle =
    activeLang === "es"
        ? "Pol Sánchez — Productor y editor de vídeo"
        : "Pol Sánchez — Video producer & editor";
const pageDesc = String(t.hero_role_desc || "");
const base = `/${activeLang}`;
---

<BaseLayout activeLang={activeLang} t={t} title={pageTitle} description={pageDesc} activeNav="home" editMode={editMode}>
    <!-- HERO -->
    <section class="hero" id="top">
        <div class="container">
            <div class="hero-top reveal">
                <h1>
                    <span data-cms-key={ek("hero_title_1")}>{text("hero_title_1")}</span><br />
                    <span data-cms-key={ek("hero_title_2")}>{text("hero_title_2")}</span> <b data-cms-key={ek("hero_title_3")}>{text("hero_title_3")}</b><br />
                    <span data-cms-key={ek("hero_title_4")}>{text("hero_title_4")}</span> <span class="accent" data-cms-key={ek("hero_title_accent")}>{text("hero_title_accent")}</span>.
                </h1>
                <div class="hero-meta">
                    <span class="mono">{t.hero_role_label}</span>
                    <p class="role" set:html={text("hero_role_desc")} data-cms-key={ek("hero_role_desc")} />
                    <div class="hero-actions">
                        <a class="btn solid" href="#work">{t.hero_cta_work} <span class="arr">→</span></a>
                        <a class="btn ghost" href="#contact">{t.hero_cta_contact}</a>
                    </div>
                </div>
            </div>

            <div class="showreel reveal" style="transition-delay:.15s">
                <span class="sr-counter"><span class="live-dot"></span> {t.hero_showreel_label}</span>
                {!showreelYtId && !showreelIsMp4 && (
                    <a class="sr-play" href="#work">
                        <span class="ico"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></span>
                        {t.hero_showreel_play}
                    </a>
                )}
                {showreelYtId ? (
                    <div class="sr-video" data-yt-showreel={showreelYtId}>
                        <img src={heroImage} alt="Showreel cover" data-cms-slot={ek("hero.showreel")} />
                    </div>
                ) : showreelIsMp4 ? (
                    <video
                        class="sr-video"
                        src={showreelVideoUrl}
                        poster={heroImage}
                        autoplay
                        muted
                        loop
                        playsinline
                        data-cms-slot={ek("hero.showreel")}
                    ></video>
                ) : (
                    <img src={heroImage} alt="Showreel cover" data-cms-slot={ek("hero.showreel")} />
                )}
                <div class="sr-meta">
                    <div class="title"><span data-cms-key={ek("hero_showreel_title")}>{text("hero_showreel_title")}</span> <small data-cms-key={ek("hero_showreel_specs")}>{text("hero_showreel_specs")}</small></div>
                    <div class="info"><b data-cms-key={ek("hero_showreel_pieces")}>{text("hero_showreel_pieces")}</b><br /><span data-cms-key={ek("hero_showreel_roles")}>{text("hero_showreel_roles")}</span><br /><span data-cms-key={ek("hero_showreel_location")}>{text("hero_showreel_location")}</span></div>
                </div>
            </div>

            <div class="hero-stats reveal" style="transition-delay:.3s">
                <div class="stat"><div class="n"><b>{t.stat_1_value}</b><sup>{t.stat_1_unit}</sup></div><div class="l">{t.stat_1_label}</div></div>
                <div class="stat"><div class="n"><b>{t.stat_2_value}</b><sup>{t.stat_2_unit}</sup></div><div class="l">{t.stat_2_label}</div></div>
                <div class="stat"><div class="n"><b>{t.stat_3_value}</b><sup>{t.stat_3_unit}</sup></div><div class="l">{t.stat_3_label}</div></div>
                <div class="stat"><div class="n"><b>{t.stat_4_value}</b><sup>{t.stat_4_unit}</sup></div><div class="l">{t.stat_4_label}</div></div>
            </div>
        </div>
    </section>

    <!-- LOGOS -->
    <div class="logos">
        <div class="logos-inner">
            <span class="logos-label">{t.logos_label}</span>
            <div class="logos-track">
                {logoNames.map((name) => <span set:html={name} />)}
                {logoNames.map((name) => <span set:html={name} />)}
            </div>
        </div>
    </div>

    <!-- WORK -->
    <section id="work">
        <div class="container">
            <div class="s-head reveal">
                <span class="num">{t.work_num}</span>
                <h2 set:html={text("work_title")} data-cms-key={ek("work_title")} />
                <span class="aside"><b data-cms-key={ek("work_aside_title")}>{text("work_aside_title")}</b><span data-cms-key={ek("work_aside_desc")}>{text("work_aside_desc")}</span></span>
            </div>

            <div class="work-filters reveal">
                <button class="chip active" data-filter="all">{t.work_filter_all} <span class="count">{String(horizontalCounts.all).padStart(2, "0")}</span></button>
                <button class="chip" data-filter="clips">{t.work_filter_clips} <span class="count">{String(horizontalCounts.clips).padStart(2, "0")}</span></button>
                <button class="chip" data-filter="ads">{t.work_filter_ads} <span class="count">{String(horizontalCounts.ads).padStart(2, "0")}</span></button>
                <button class="chip" data-filter="youtube">{t.work_filter_youtube} <span class="count">{String(horizontalCounts.youtube).padStart(2, "0")}</span></button>
                <button class="chip" data-filter="doc">{t.work_filter_doc} <span class="count">{String(horizontalCounts.doc).padStart(2, "0")}</span></button>
            </div>

            <div class="work-grid">
                {horizontal.map((p, i) => {
                    const size = p.size ?? "eq";
                    const cover = p.cover || "/images/portfolio-irl.png";
                    const ytId = youtubeId(p.videoUrl);
                    const tagLine = [p.format, p.duration].filter(Boolean).join(" · ");
                    return (
                        <a
                            class={`case ${size} reveal`}
                            style={i > 0 ? `transition-delay:${(i % 3) * 0.08}s` : undefined}
                            href={`${base}/project/${p.id}`}
                            data-yt={ytId ?? undefined}
                        >
                            <div class="ph">
                                <img src={cover} alt={p.title} loading={i < 2 ? "eager" : "lazy"} />
                            </div>
                            <span class="num-pin">{String(i + 1).padStart(2, "0")} / {String(horizontal.length).padStart(2, "0")}</span>
                            {ytId && <span class="play-pin"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></span>}
                            <div class="meta">
                                <h3>{p.title}{p.subtitle && <small>{p.subtitle}</small>}</h3>
                                {tagLine && <span class="tag">{tagLine}</span>}
                            </div>
                        </a>
                    );
                })}
            </div>

            <div class="work-more reveal">
                <a class="btn ghost" href={`${base}/portfolio`}><span data-cms-key={ek("work_more")}>{text("work_more")}</span> <span class="arr">→</span></a>
            </div>
        </div>
    </section>

    <!-- VERTICAL -->
    <section class="vertical-section" id="vertical">
        <div class="container">
            <div class="s-head reveal">
                <span class="num">{t.vertical_num}</span>
                <h2 set:html={text("vertical_title")} data-cms-key={ek("vertical_title")} />
                <span class="aside"><b data-cms-key={ek("vertical_aside_title")}>{text("vertical_aside_title")}</b><span data-cms-key={ek("vertical_aside_desc")}>{text("vertical_aside_desc")}</span></span>
            </div>

            <div class="v-grid">
                {vertical.map((p, i) => {
                    const cover = p.cover || "/images/portfolio-music.png";
                    const ytId = youtubeId(p.videoUrl);
                    return (
                        <a
                            class="phone reveal"
                            style={i > 0 ? `transition-delay:${(i % 5) * 0.08}s` : undefined}
                            href={`${base}/project/${p.id}`}
                            data-yt-vertical={ytId ?? undefined}
                        >
                            <div class="phone-shell">
                                <div class="phone-notch"></div>
                                <div class="phone-screen">
                                    <img src={cover} alt={p.title} loading="lazy" />
                                    <div class="phone-cap">
                                        <h4>{p.title}</h4>
                                        {p.subtitle && <span>{p.subtitle}</span>}
                                    </div>
                                </div>
                            </div>
                            <div class="phone-info">
                                <b>{p.views || "—"}</b>
                                <span>{p.platform || ""}</span>
                            </div>
                        </a>
                    );
                })}
            </div>
        </div>
    </section>

    <!-- PROCESS -->
    <section id="process">
        <div class="container">
            <div class="process-wrap">
                <div class="process-aside reveal">
                    <span class="num mono">{t.process_num}</span>
                    <h3 style="margin-top:14px" set:html={text("process_title")} data-cms-key={ek("process_title")} />
                    <p data-cms-key={ek("process_desc")}>{text("process_desc")}</p>
                    <span class="badge" data-cms-key={ek("process_badge")}>{text("process_badge")}</span>
                </div>
                <div class="steps">
                    {processSteps.map((step, i) => (
                        <div class="step reveal" style={i > 0 ? `transition-delay:${i * 0.06}s` : undefined}>
                            <span class="n">{step.num}</span>
                            <div>
                                <h4 data-cms-key={ek(step.titleKey)}>{text(step.titleKey)}</h4>
                                <p data-cms-key={ek(step.descKey)}>{text(step.descKey)}</p>
                            </div>
                            <span class="when">{t[step.timeKey]}</span>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ABOUT -->
    <section id="about">
        <div class="container">
            <div class="about">
                <div class="about-portrait reveal">
                    <img src={aboutImage} alt={String(t.about_portrait_alt)} data-cms-slot={ek("about.portrait")} />
                    <span class="name-tag"><b data-cms-key={ek("about_portrait_tag")}>{text("about_portrait_tag")}</b> · <span data-cms-key={ek("about_portrait_role")}>{text("about_portrait_role")}</span></span>
                </div>
                <div class="about-copy reveal" style="transition-delay:.1s">
                    <span class="mono" style="display:block;margin-bottom:18px">{t.about_num}</span>
                    <h2 set:html={text("about_title")} data-cms-key={ek("about_title")} />
                    <p class="lead" data-cms-key={ek("about_lead")}>{text("about_lead")}</p>
                    <p data-cms-key={ek("about_p1")}>{text("about_p1")}</p>
                    <p data-cms-key={ek("about_p2")}>{text("about_p2")}</p>
                    <div class="facts">
                        <div class="fact"><span>{t.about_fact_1_label}</span><b>{t.about_fact_1_value}</b></div>
                        <div class="fact"><span>{t.about_fact_2_label}</span><b>{t.about_fact_2_value}</b></div>
                        <div class="fact"><span>{t.about_fact_3_label}</span><b>{t.about_fact_3_value}</b></div>
                        <div class="fact"><span>{t.about_fact_4_label}</span><b>{t.about_fact_4_value}</b></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" style="border-bottom:0">
        <div class="container">
            <div class="contact">
                <div class="contact-intro reveal">
                    <span class="mono" style="display:block;margin-bottom:18px">{t.contact_num}</span>
                    <h2 set:html={text("contact_title")} data-cms-key={ek("contact_title")} />
                    <p data-cms-key={ek("contact_desc")}>{text("contact_desc")}</p>

                    <div class="contact-channels">
                        <a class="channel" href={`mailto:${t.contact_email}`}>
                            <span class="ico"><svg viewBox="0 0 24 24"><path d="M4 6h16v12H4z"/><path d="M4 6l8 7 8-7"/></svg></span>
                            <div class="body"><span>{t.contact_email_label}</span><b>{t.contact_email}</b></div>
                            <span class="arr">→</span>
                        </a>
                        <a class="channel" href={`tel:${String(t.contact_phone).replace(/\s+/g, "")}`}>
                            <span class="ico"><svg viewBox="0 0 24 24"><path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg></span>
                            <div class="body"><span>{t.contact_phone_label}</span><b>{t.contact_phone}</b></div>
                            <span class="arr">→</span>
                        </a>
                        <a class="channel" href="#">
                            <span class="ico"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="4"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg></span>
                            <div class="body"><span>{t.contact_social_label}</span><b>{t.contact_social}</b></div>
                            <span class="arr">→</span>
                        </a>
                    </div>
                </div>

                <form class="form-card reveal" style="transition-delay:.1s" id="contact-form">
                    <h3 data-cms-key={ek("contact_form_title")}>{text("contact_form_title")}</h3>
                    <p class="lead-line" data-cms-key={ek("contact_form_lead")}>{text("contact_form_lead")}</p>
                    <div class="form-grid">
                        <div class="row2">
                            <div class="field">
                                <label for="form-name">{t.form_name}</label>
                                <input id="form-name" name="name" required placeholder={String(t.form_name_placeholder)} autocomplete="name" />
                            </div>
                            <div class="field">
                                <label for="form-email">{t.form_email}</label>
                                <input id="form-email" name="email" type="email" required placeholder={String(t.form_email_placeholder)} autocomplete="email" />
                            </div>
                        </div>
                        <div class="row2">
                            <div class="field">
                                <label for="form-project">{t.form_project_type}</label>
                                <select id="form-project" name="project">
                                    {projectOptions.map((opt) => <option>{opt}</option>)}
                                </select>
                            </div>
                            <div class="field">
                                <label for="form-budget">{t.form_budget}</label>
                                <select id="form-budget" name="budget">
                                    {budgetOptions.map((opt) => <option>{opt}</option>)}
                                </select>
                            </div>
                        </div>
                        <div class="field">
                            <label for="form-message">{t.form_message}</label>
                            <textarea id="form-message" name="message" required placeholder={String(t.form_message_placeholder)}></textarea>
                        </div>
                        <div class="form-submit">
                            <span class="note" id="form-note">{t.form_note}</span>
                            <button class="btn solid" type="submit">{t.form_submit} <span class="arr">→</span></button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <script is:inline>
        // Chip filter (visual only)
        document.querySelectorAll('.work-filters .chip').forEach(function (c) {
            c.addEventListener('click', function () {
                document.querySelectorAll('.work-filters .chip').forEach(function (o) { o.classList.remove('active'); });
                c.classList.add('active');
            });
        });

        // Form submit (UI only)
        (function () {
            var form = document.getElementById('contact-form');
            var note = document.getElementById('form-note');
            if (form && note) {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    note.textContent = note.dataset.success || 'Mensaje recibido.';
                });
            }
        })();

        // Hover-to-play YouTube
        (function () {
            var ytParams = 'autoplay=1&mute=1&controls=0&showinfo=0&rel=0&iv_load_policy=3&modestbranding=1&disablekb=1&fs=0&playsinline=1&loop=1';
            document.querySelectorAll('[data-yt]').forEach(function (card) {
                var id = card.getAttribute('data-yt');
                if (!id) return;
                var ph = card.querySelector('.ph');
                var iframe = null;
                card.addEventListener('mouseenter', function () {
                    if (!iframe) {
                        iframe = document.createElement('iframe');
                        iframe.src = 'https://www.youtube.com/embed/' + id + '?' + ytParams + '&playlist=' + id;
                        iframe.allow = 'autoplay; encrypted-media';
                        iframe.setAttribute('loading', 'lazy');
                        iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;z-index:1;pointer-events:none;';
                    }
                    ph.appendChild(iframe);
                });
                card.addEventListener('mouseleave', function () {
                    if (iframe && iframe.parentNode) {
                        iframe.parentNode.removeChild(iframe);
                        iframe.src = '';
                        iframe = null;
                    }
                });
            });
            // Showreel autoplay YouTube
            (function () {
                var sr = document.querySelector('[data-yt-showreel]');
                if (!sr) return;
                var id = sr.getAttribute('data-yt-showreel');
                if (!id) return;
                var iframe = document.createElement('iframe');
                iframe.src = 'https://www.youtube.com/embed/' + id + '?' + ytParams + '&playlist=' + id;
                iframe.allow = 'autoplay; encrypted-media';
                iframe.setAttribute('loading', 'lazy');
                iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;pointer-events:none;';
                sr.appendChild(iframe);
            })();

            document.querySelectorAll('[data-yt-vertical]').forEach(function (card) {
                var id = card.getAttribute('data-yt-vertical');
                if (!id) return;
                var screen = card.querySelector('.phone-screen');
                var iframe = null;
                card.addEventListener('mouseenter', function () {
                    if (!iframe) {
                        iframe = document.createElement('iframe');
                        iframe.src = 'https://www.youtube.com/embed/' + id + '?' + ytParams + '&playlist=' + id;
                        iframe.allow = 'autoplay; encrypted-media';
                        iframe.setAttribute('loading', 'lazy');
                        iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;z-index:2;pointer-events:none;object-fit:cover;';
                    }
                    screen.appendChild(iframe);
                });
                card.addEventListener('mouseleave', function () {
                    if (iframe && iframe.parentNode) {
                        iframe.parentNode.removeChild(iframe);
                        iframe.src = '';
                        iframe = null;
                    }
                });
            });
        })();
    </script>
    <script is:inline define:vars={{ formSuccess: t.form_success }}>
        var note = document.getElementById('form-note');
        if (note) note.dataset.success = formSuccess;
    </script>
</BaseLayout>
