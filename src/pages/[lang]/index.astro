---
import type { ActiveLang } from "../../i18n";
import { LANGS, DEFAULT_LANG, getDict } from "../../i18n";
import { projects } from "../../data/projects";
import SiteHeader from "../../components/SiteHeader.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
    return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang?: ActiveLang };
const activeLang = lang ?? DEFAULT_LANG;
const t = await getDict(activeLang);

const siteUrl = Astro.site ? Astro.site.origin : "https://polobkstudios.com";
const currentUrl = `${siteUrl}/${activeLang}/`;
const heroImage = "/images/hero-showreel-cover.jpg";

const featuredProjects = [...projects];

const services = [
    { title: t.home_service_1_title, desc: t.home_service_1_desc, image: "/images/portfolio-youtube-high-retention.png" },
    { title: t.home_service_2_title, desc: t.home_service_2_desc, image: "/images/portfolio-music-video-neon-pulse.png" },
    { title: t.home_service_3_title, desc: t.home_service_3_desc, image: "/images/portfolio-irl-barcelona-night-run.png" },
    { title: t.home_service_4_title, desc: t.home_service_4_desc, image: "/images/portfolio-brand-product-teaser.png" },
];
---

<html lang={activeLang}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>POL Producciones</title>
        <meta name="description" content={t.home_hero_desc} />
        <meta property="og:title" content="POL Producciones" />
        <meta property="og:description" content={t.home_hero_desc} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={currentUrl} />
        <meta property="og:image" content={`${siteUrl}${heroImage}`} />
    </head>

    <body id="top" class="site-bg min-h-screen text-brand-text antialiased">
        <SiteHeader activeLang={activeLang} t={t} />

        <main class="mx-auto max-w-6xl px-4 pb-20 pt-28 md:pt-32">
            <section class="scroll-section grid gap-8 py-10 md:grid-cols-[1fr_1.2fr] md:py-14">
                <div>
                    <h1 class="text-5xl font-black leading-[0.95] md:text-7xl">{t.home_hero_title}</h1>
                    <p class="mt-6 max-w-md text-2xl text-white/85">{t.home_hero_desc}</p>
                    <div class="mt-8 flex gap-3">
                        <a class="gold-btn rounded-md px-8 py-3 text-xl font-bold text-black" href="#">{t.home_watch}</a>
                        <a class="rounded-md border border-white/40 px-8 py-3 text-xl" href={`/${activeLang}/contacto/`}>{t.home_contact}</a>
                    </div>
                    <div class="mt-8 flex gap-10 text-4xl font-black">
                        <p>+120 <span class="text-xl font-medium text-white/70">{t.home_stat_projects}</span></p>
                        <p>+30M <span class="text-xl font-medium text-white/70">{t.home_stat_views}</span></p>
                    </div>
                </div>

                <article class="gold-frame relative overflow-hidden rounded-sm p-5">
                    <img src={heroImage} alt={t.home_reel} class="h-full w-full object-cover opacity-75" />
                    <div class="absolute inset-5 bg-gradient-to-t from-black via-black/20 to-black/60"></div>
                    <h2 class="absolute left-10 top-10 text-5xl font-bold">{t.home_reel}</h2>
                </article>
            </section>

            <section id="featured" class="scroll-section border-t border-white/25 py-8">
                <h2 class="mb-5 text-4xl font-black">{t.home_featured}</h2>
                <div class="grid gap-4 md:grid-cols-3">
                    {featuredProjects.map((item) => (
                        <article class="project-card overflow-hidden border border-white/20 bg-black/50">
                            <div class="relative h-56">
                                <img src={item.heroImage} alt={item.title} class="h-full w-full object-cover" />
                                <span class="absolute left-4 top-4 rounded bg-black/80 px-3 py-1 text-sm font-semibold">{item.tag}</span>
                            </div>
                            <div class="p-5">
                                <h3 class="text-4xl font-bold">{item.title}</h3>
                                <p class="mt-2 text-xl text-white/75">{item.shortDescription}</p>
                                <a class="gold-btn mt-4 inline-block rounded px-4 py-2 font-bold text-black" href={`/${activeLang}/trabajos/${item.slug}/`}>
                                    {t.home_view_project}
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
            </section>

            <section id="services" class="scroll-section border-t border-white/25 py-8">
                <h2 class="mb-5 text-4xl font-black">{t.home_premium}</h2>
                <div class="grid gap-4 md:grid-cols-4">
                    {services.map((item) => (
                        <article class="project-card overflow-hidden border border-white/20 bg-black/50">
                            <img src={item.image} alt={item.title} class="h-44 w-full object-cover" />
                            <div class="p-5">
                                <h3 class="text-4xl font-bold">{item.title}</h3>
                                <p class="mt-2 text-xl text-white/75">{item.desc}</p>
                            </div>
                        </article>
                    ))}
                </div>
            </section>

            <section id="contact" class="scroll-section grid gap-8 border-t border-white/25 py-12 md:grid-cols-2">
                <div>
                    <h2 class="text-5xl font-black">{t.home_ready}</h2>
                    <p class="mt-5 text-3xl text-white/85">{t.home_ready_desc}</p>
                    <p class="mt-4 text-lg text-white/65">{t.home_location}</p>
                    <a class="gold-btn mt-6 inline-block rounded-md px-7 py-3 text-2xl font-bold text-black" href={`/${activeLang}/contacto/`}>{t.home_contact}</a>
                </div>

                <form class="border border-white/25 bg-black/40 p-6">
                    <input class="form-line" placeholder={t.form_name} />
                    <input class="form-line" placeholder={t.form_email} />
                    <textarea class="form-line h-28" placeholder={t.form_message}></textarea>
                    <div class="mt-6 text-right">
                        <button class="gold-btn rounded-md px-10 py-3 text-2xl font-bold text-black" type="submit">{t.home_send}</button>
                    </div>
                </form>
            </section>
        </main>

        <script is:inline>
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-visible");
                        }
                    });
                },
                { threshold: 0.2, rootMargin: "0px 0px -60px 0px" },
            );

            document.querySelectorAll(".scroll-section").forEach((section) => {
                observer.observe(section);
            });
        </script>
    </body>
</html>
