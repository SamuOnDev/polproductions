---
import type { ActiveLang } from "../../i18n";
import { LANGS, DEFAULT_LANG, getDict } from "../../i18n";
import SiteHeader from "../../components/SiteHeader.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
    return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang?: ActiveLang };
const activeLang = lang ?? DEFAULT_LANG;
const t = await getDict(activeLang);
---

<html lang={activeLang}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>{t.about_page_title}</title>
        <meta name="description" content={t.about_page_description} />
    </head>

    <body class="site-bg min-h-screen text-brand-text antialiased">
        <SiteHeader activeLang={activeLang} t={t} />

        <main class="mx-auto max-w-4xl px-4 pb-20 pt-28 md:pt-32">
            <section class="scroll-section rounded-xl border border-white/20 bg-black/45 p-6 md:p-10">
                <p class="text-sm tracking-[0.2em] text-brand-accent">{t.about_subtitle.toUpperCase()}</p>
                <h1 class="mt-3 text-4xl font-black md:text-6xl">{t.about_heading}</h1>

                <article class="mt-10 space-y-6 text-lg leading-relaxed text-white/90">
                    <p>{t.about_greeting}</p>
                    <p>{t.about_p1}</p>
                    <p>{t.about_p2}</p>
                    <p>{t.about_p3}</p>
                    <p>{t.about_p4}</p>
                    <p class="pt-6">{t.about_farewell}<br /><strong>{t.about_signature}</strong></p>
                </article>

                <div class="mt-10 border-t border-white/20 pt-6">
                    <p class="text-white/75">{t.about_note}</p>
                    <a href={`/${activeLang}/contacto/`} class="gold-btn mt-5 inline-block rounded-md px-7 py-3 font-bold text-black">{t.about_cta}</a>
                </div>
            </section>
        </main>

        <script is:inline>
            const section = document.querySelector(".scroll-section");
            if (section) {
                requestAnimationFrame(() => section.classList.add("is-visible"));
            }
        </script>
    </body>
</html>
