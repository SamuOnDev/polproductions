---
import type { ActiveLang, LocaleTexts } from "../i18n";
import ThemeScript from "../components/ThemeScript.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AdminFab from "../components/AdminFab.astro";
import "../styles/global.css";

interface Props {
    activeLang: ActiveLang;
    t: LocaleTexts;
    title: string;
    description?: string;
    canonical?: string;
    ogImage?: string;
    activeNav?: "home" | "portfolio";
    /** Hide the public chrome (Admin FAB) when rendering inside the editor iframe. */
    editMode?: boolean;
}

const { activeLang, t, title, description = "", canonical, ogImage, activeNav = "home", editMode = false } = Astro.props;
const siteUrl = Astro.site ? Astro.site.origin : "https://polsanchezbaena.com";
const currentUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImg = ogImage ?? `${siteUrl}/images/hero-showreel-cover.jpg`;
const descStripped = description.replace(/<[^>]*>/g, "");
---
<html lang={activeLang}>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={descStripped} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={descStripped} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:image" content={ogImg} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={currentUrl} />
    <link rel="alternate" hreflang="es" href={`${siteUrl}/es${Astro.url.pathname.replace(/^\/(es|en)/, "")}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}/en${Astro.url.pathname.replace(/^\/(es|en)/, "")}`} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <ThemeScript />
</head>
<body>
    <a href="#main-content" class="skip-link">{t.skip_to_content}</a>
    <Nav activeLang={activeLang} t={t} activeKey={activeNav} />
    <main id="main-content">
        <slot />
    </main>
    <Footer activeLang={activeLang} t={t} />
    {!editMode && <AdminFab t={t} />}
    <script is:inline>
        document.documentElement.classList.add('js');
        (function () {
            if (!('IntersectionObserver' in window)) {
                document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('in'); });
                return;
            }
            var io = new IntersectionObserver(function (entries) {
                entries.forEach(function (e) {
                    if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
                });
            }, { rootMargin: '0px 0px -5% 0px', threshold: 0.05 });
            document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
            requestAnimationFrame(function () {
                document.querySelectorAll('.reveal').forEach(function (el) {
                    var r = el.getBoundingClientRect();
                    if (r.top < window.innerHeight * 0.95) { el.classList.add('in'); io.unobserve(el); }
                });
            });
            setTimeout(function () {
                if (document.querySelectorAll('.reveal.in').length === 0) {
                    document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('in'); });
                }
            }, 1200);
        })();
    </script>
</body>
</html>
